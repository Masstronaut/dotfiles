{
	"$schema": "https://komorebi-for-mac.lgug2z.com/komorebi.0.1.0.schema.json",
	"app_specific_configuration_path": "$HOME/.config/komorebi/applications.json",
	"cross_monitor_move_behaviour": "Insert",
	"default_workspace_padding": 4,
	"default_container_padding": 4,
	"border": true,
	"theme": {
		"palette": "Base16",
		"name": "RosePineDawn"
	},
	"border_width": 4,
	"border_offset": -3,
	"border_radius": 16,
	"floating_window_aspect_ratio": "Widescreen",
	"floating_layer_behaviour": "Float",
	"float_override_placement": "Center",
	"resize_delta": 100,
	"ignore_rules": [],
	"global_work_area_offset": {
		"top": 26,
		"right": 0,
		"bottom": 24,
		"left": 0
	},
	"floating_applications": [
		{
			"matching_strategy": "Contains",
			"id": "Settings",
			"kind": "Title"
		},
		{
			"matching_strategy": "Contains",
			"id": "System Preferences",
			"kind": "Title"
		},
		{
			"matching_strategy": "Contains",
