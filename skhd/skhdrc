# Focus windows
rshift - h                 : komorebic focus left
rshift - j                 : komorebic focus down
rshift - k                 : komorebic focus up
rshift - l                 : komorebic focus right
lshift + rshift - 0x21      : komorebic cycle-focus previous # 0x21 is [
lshift + rshift - 0x1E      : komorebic cycle-focus next # 0x1E is ]

# Move windows
lshift + rshift - h         : komorebic move left
lshift + rshift - j         : komorebic move down
lshift + rshift - k         : komorebic move up
lshift + rshift - l         : komorebic move right
lshift + rshift - return    : komorebic promote

# multi-monitor config
lshift + rshift - tab		: komorebic cycle-move-workspace-to-monitor next 
rshift - tab				: komorebic cycle-monitor next

# Stack windows
lshift + rshift - left       : komorebic stack left
lshift + rshift - down       : komorebic stack down
lshift + rshift - up         : komorebic stack up
lshift + rshift - right      : komorebic stack right
rshift - 0x29              : komorebic unstack # 0x29 is ;
rshift - 0x21              : komorebic cycle-stack previous # 0x21 is [
rshift - 0x1E              : komorebic cycle-stack next # 0x1E is ]

# Workspace layer
lshift + rshift - 0x29      : komorebic toggle-workspace-layer # 0x29 is ;

# Resize
rshift			- 0x18		: komorebic resize-axis horizontal increase # 0x18 is +
rshift			- 0x1B		: komorebic resize-axis horizontal decrease # 0x1B is -
lshift + rshift	- 0x18		: komorebic resize-axis vertical increase
lshift + rshift	- 0x1B		: komorebic resize-axis vertical decrease

# Manipulate windows
rshift          - 0x2F		: komorebic manage # 0x2F is .
rshift			- space		: komorebic toggle-float
lshift + rshift	- space		: komorebic toggle-workspace-float-override
lshift + rshift	- f			: komorebic toggle-monocle

# Window manager options
lshift + rshift	- r		: komorebic retile
rshift			- p		: komorebic toggle-pause
rshift			- 0		: komorebic toggle-window-container-behaviour

# Layouts
rshift			- x		: komorebic flip-layout horizontal
rshift			- y		: komorebic flip-layout vertical
lshift + rshift	- x		: komorebic session-float-rule

